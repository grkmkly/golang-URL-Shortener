{
    "version": 2,
    "builds": [
      {
        "src": "api/index.go",
        "use": "@vercel/go"
      }
    ],
    "routes": [
      { "src": "/", "dest": "/homepage.html" },
      { "src": "/action-url", "dest": "/main.go" },
      { "src": "/linkpage", "dest": "/linkpage.html" },
      { "src": "/(.*)", "dest": "/$1" }
    ]
  }